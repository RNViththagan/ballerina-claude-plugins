{
  "description": "Enforce ballerina skill activation before writing .bal files",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bal-skill-remind.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
